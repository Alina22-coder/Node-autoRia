# App
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# DATABASE — cloud PostgreSQL (Neon recommended)
# https://neon.tech — free tier
#
# Local (docker-compose local postgres):
#   DB_HOST=localhost
#   DB_SSL=false
#
# Cloud (Neon example):
#   DB_HOST=ep-xxx-xxx.us-east-2.aws.neon.tech
#   DB_SSL=true
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autoria
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# ─────────────────────────────────────────────
# REDIS — cloud Redis (Upstash recommended)
# https://upstash.com — free tier
#
# Local (docker-compose local redis):
#   REDIS_HOST=localhost
#   REDIS_PASSWORD=
#   REDIS_TLS=false
#
# Cloud (Upstash example):
#   REDIS_HOST=your-db.upstash.io
#   REDIS_PASSWORD=your_upstash_password
#   REDIS_TLS=true
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Email (nodemailer / Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=your_app_password
MAIL_FROM=noreply@autoria.com

# Privat Bank API (public, no key required)
PRIVAT_BANK_API_URL=https://api.privatbank.ua/p24api/pubinfo?exchange&coursid=5
