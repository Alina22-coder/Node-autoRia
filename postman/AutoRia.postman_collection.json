              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has brands array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                  "pm.test('Has 20 brands', () => pm.expect(pm.response.json().data.length).to.eql(20));"
