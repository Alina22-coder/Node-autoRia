    },
    {
      "name": "3. Currency",
      "description": "Крок 3: Курси валют UAH/USD/EUR від ПриватБанку.\nКурси оновлюються щодня о 9:00 автоматично.",
      "item": [
        {
          "name": "Get Rates",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json().data;",
                  "pm.test('Has USD rate', () => pm.expect(d).to.have.property('USD'));",
                  "pm.test('Has EUR rate', () => pm.expect(d).to.have.property('EUR'));",
                  "pm.test('UAH = 1', () => pm.expect(d.UAH).to.eql(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/currency",
            "description": "Повертає поточні курси UAH/USD/EUR. Кешується в Redis."
          }
        },
        {
          "name": "Refresh Rates (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
